<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
  Version="7.0"
  ExtensionBundleId="com.thomados.funbox"
  ExtensionBundleVersion="1.3.0"
  ExtensionBundleName="Thomados FunBox"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.thomados.funbox.panel" Version="1.3.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="[26.2.2,26.2.2]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="12.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.thomados.funbox.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./host/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--high-dpi-support=1</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Thomados FunBox</Menu>
          <Geometry>
            <Size>
              <Width>420</Width>
              <Height>720</Height>
            </Size>
            <MinSize>
              <Width>360</Width>
              <Height>480</Height>
            </MinSize>
            <MaxSize>
              <Width>1200</Width>
              <Height>1200</Height>
            </MaxSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
