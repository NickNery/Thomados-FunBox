{
  "name": "thomados-funbox",
  "version": "1.8.0",
  "private": true,
  "description": "Adobe CEP panel for Premiere Pro built with React, TypeScript, Tailwind CSS, Vite, and ExtendScript.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && npm run validate:host && npm run validate:downloader && vite build && node scripts/copy-cep-assets.mjs",
    "install:cep": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-cep.ps1",
    "preview": "vite preview --host 127.0.0.1",
    "test:host": "node scripts/test-host.mjs",
    "typecheck": "tsc --noEmit",
    "validate:host": "node scripts/validate-host.mjs",
    "validate:downloader": "node scripts/validate-downloader.mjs"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "lucide-react": "^0.468.0",
    "ogl": "^1.0.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "4.7.0",
    "acorn": "8.15.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "6.4.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
